
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model User {
  id        String    @id @default(cuid())
  name      String?
  imageUrl  String?   @db.Text
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Room {
  id        String    @id @default(cuid())
  name      String
  messages  Message[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Message {
  id           String   @id @default(cuid())
  content      String   @db.Text
  
  // 링크 프리뷰를 위한 필드 추가
  linkPreview  String?  @db.Text // JSON 형태로 저장하거나 구분자를 사용
  previewTitle String?
  previewDesc  String?
  previewImage String?
  previewUrl   String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  roomId    String
  room      Room     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([roomId])
}
